DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=volleyops
SECRET_KEY=choose_a_long_random_secret
# Optional values
OPENAI_API_KEY=
CORS_ORIGIN=http://localhost:5173

# Notes:
# - Copy this file to backend/.env and fill in values before running the backend.
# - The backend will attempt to create the database named in DB_NAME on startup
#   if the MySQL server is reachable with the provided credentials.